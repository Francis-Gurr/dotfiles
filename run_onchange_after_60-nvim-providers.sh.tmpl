#!/bin/sh
# Best-effort nvim providers (npm + python); non-fatal.
set -eu

export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$PNPM_HOME/bin:$PATH"
if command -v pnpm >/dev/null 2>&1; then
	pnpm add -g neovim markdownlint || true
fi
if command -v python3 >/dev/null 2>&1; then
	python3 -m pip install --user --break-system-packages --upgrade pynvim pylatexenc >/dev/null 2>&1 || true
fi
