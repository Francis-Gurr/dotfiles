#!/usr/bin/env bash
#
# Route specific company hosts through the FortiClient VPN.
#
# Background: FortiClient on this machine uses IPsec/XFRM with the VPN IP
# (10.0.192.x) assigned as a secondary address on the wifi NIC rather than a
# separate tun device. Home LAN is 10.0.0.0/24, which overlaps the corporate
# /24, so company hosts like gitlab.agile-robots.com (10.0.0.100) get matched
# by the kernel's on-link LAN route and never enter the tunnel. Adding a /32
# host route with src = VPN IP wins longest-prefix match and triggers the
# XFRM outbound policy to encrypt.
#
# Routing alone isn't enough for GitLab Pages (storybook previews). git.ar.int is
# pinned in /etc/hosts so it resolves without DNS, but every MR gets its own
# wildcard *.pages.int subdomain that can't be hard-coded — it needs a working
# corporate resolver. FortiClient often fails to push DNS into systemd-resolved,
# leaving only the home router (which can't resolve *.int), so we also put the corp
# resolvers first on the VPN NIC. They're 10.1.x, reachable via the tunnel's
# default route. Revert that part with: resolvectl revert <NIC>
#
# Run after each VPN connect. Idempotent — safe to re-run.

set -e

source "$(dirname "$(readlink -f "$0")")/.shell_utils.sh"

HOSTS=(
    10.0.0.100   # gitlab.agile-robots.com / git.ar.int
    10.0.0.101   # *.pages.int (GitLab Pages)
    10.0.0.104   # artifactory.agile-robots.de
    10.0.0.113   # testrail.agile-robots.app
)

NIC=$(ip -br addr | awk '/10\.0\.192\./ {print $1; exit}')
VPNIP=$(ip -o addr show "$NIC" 2>/dev/null \
    | awk '/inet 10\.0\.192\./ {split($4,a,"/"); print a[1]; exit}')

if [[ -z "$NIC" || -z "$VPNIP" ]]; then
    out_red "VPN not connected — no 10.0.192.x address found on any interface."
    out_red "Connect FortiClient first, then re-run this script."
    exit 1
fi

out_yellow "VPN interface: $NIC (source IP $VPNIP)"

for h in "${HOSTS[@]}"; do
    sudo ip route replace "$h/32" dev "$NIC" scope link src "$VPNIP"
    out_green "  routed $h/32 via $NIC"
done

# DNS: resolve *.pages.int / *.ar.int via a corp resolver reachable over the tunnel.
# FortiClient pushes 10.0.0.1 as corp DNS, but that IP collides with the home router
# across the /24 overlap, so those queries hit the home router, which answers NXDOMAIN.
# systemd-resolved latches one current server per link and only fails over on a hard
# error — not on NXDOMAIN — so a home-router 10.0.0.1 in the list wins with a confident
# wrong answer. We therefore set the corp resolvers (10.1.x, tunnel-routed) as the ONLY
# servers on the NIC and claim pages.int/ar.int as routing domains so those names go
# here. Corp DNS does full public recursion, so general lookups still work while up;
# NetworkManager/FortiClient restore home DNS on disconnect. Revert: resolvectl revert "$NIC"
CORP_DNS=(10.1.0.152 10.1.128.1)

if command -v resolvectl >/dev/null; then
    domains=("~pages.int" "~ar.int")
    current_dom=$(resolvectl domain "$NIC" 2>/dev/null | sed 's/^Link[^:]*: //')
    for d in $current_dom; do
        [[ " ${domains[*]} " == *" $d "* ]] || domains+=("$d")
    done

    sudo resolvectl dns "$NIC" "${CORP_DNS[@]}"
    sudo resolvectl domain "$NIC" "${domains[@]}"
    resolvectl flush-caches 2>/dev/null || true
    out_green "  DNS: pages.int/ar.int -> corp resolver via $NIC (${CORP_DNS[*]})"

    if getent hosts projects.pages.int >/dev/null 2>&1; then
        out_green "  verified: projects.pages.int resolves"
    else
        out_red "  WARNING: projects.pages.int still not resolving."
        out_red "  FortiClient may have re-pushed DNS. Re-run this script, or inspect:"
        out_red "    resolvectl status $NIC"
    fi
else
    out_yellow "resolvectl not found — skipping DNS fix; *.pages.int may not resolve over VPN."
fi

out_green "Done. Test with:"
out_green "  getent hosts projects.pages.int            # should return 10.0.0.101"
out_green "  curl -sI http://projects.pages.int/ | head -1"
