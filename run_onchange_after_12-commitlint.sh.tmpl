#!/bin/sh
# Install pnpm + Node and enable the commitlint hook.
# deps: {{ include "package.json" | sha256sum }} {{ include "pnpm-lock.yaml" | sha256sum }}
set -eu

command -v pnpm >/dev/null 2>&1 || curl -fsSL https://get.pnpm.io/install.sh | sh -
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$PNPM_HOME/bin:$PATH"
pnpm runtime set node lts -g || true

cd "{{ .chezmoi.sourceDir }}"
pnpm install --frozen-lockfile
git config core.hooksPath .githooks
