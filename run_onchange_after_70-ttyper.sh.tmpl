#!/bin/sh
# Install ttyper via cargo on Linux (brew handles macOS).
set -eu
{{ if ne .chezmoi.os "darwin" -}}
if ! command -v ttyper >/dev/null 2>&1; then
	if command -v cargo >/dev/null 2>&1; then
		cargo install ttyper || true
	else
		echo "ttyper not installed: install Rust, then 'cargo install ttyper'"
	fi
fi
{{ end -}}
