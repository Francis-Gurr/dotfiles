[alias]
	fetch = ! "git fetch -p && git for-each-ref --format '%(refname:short) %(upstream:track)' | awk '$2 == \"[gone]\" {print $1}' | xargs -r git branch -D"
	glog = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
	recent = branch --sort=-committerdate --format=\"%(committerdate:relative)%09%(refname:short)\"
	rlog = "!git --no-pager log --decorate --pretty=oneline --abbrev-commit --color=always| less -N"
	stash-all = stash save --include-untracked
	undo = reset --soft HEAD^
[branch]
	sort = -committerdate
[commit]
	verbose = true
[core]
	editor = vim
	pager = delta
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
[diff]
	algorithm = histogram
	colorMoved = default
	colorMovedWS = allow-indentation-change
	submodule = log
[fetch]
	prune = true
	recurseSubmodules = on-demand
[filter "lfs"]
	clean = git-lfs clean -- %f
	process = git-lfs filter-process
	required = true
	smudge = git-lfs smudge -- %f
[help]
	autocorrect = prompt
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[merge]
	conflictStyle = zdiff3
[pull]
	rebase = true
	recurseSubmodules = on-demand
[push]
	autoSetupRemote = true
	default = simple
	recurseSubmodules = check
[rebase]
	autostash = true
[rerere]
	enabled = true
[transfer]
	fsckobjects = true
[url "git@github.com:"]
	insteadOf = https://github.com/
[user]
	email = francis.gurr@gmail.com
	name = Francis-Gurr
[submodule]
	recurse = true
[status]
	submoduleSummary = true
[includeIf "gitdir:~/dev/work/"]
	path = ~/.config/git/work.inc
